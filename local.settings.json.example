{
  "IsEncrypted": false,
  "Values": {
    "AzureWebJobsStorage": "<your-storage-connection-string>",
    "FUNCTIONS_WORKER_RUNTIME": "python",
    "TIMER_SCHEDULE": "0 */5 * * * *",
    "RUN_LOCATION": "<your-region-or-label>",
    "DNS_TARGETS": "host1.example.com;host2.example.com",
    "TCP_TARGETS": "host1.example.com:443;host2.example.com:1433",
    "APPINSIGHTS_INSTRUMENTATIONKEY": "<your-instrumentation-key>"
  }
}
